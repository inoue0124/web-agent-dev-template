#!/usr/bin/env bash
set -euo pipefail

echo "🔍 Running pre-commit checks..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Frontend checks
FE_FILES=$(echo "$STAGED_FILES" | grep '^frontend/' || true)
if [ -n "$FE_FILES" ]; then
  echo "📦 Checking frontend files..."

  # Prettier check
  FE_SRC_FILES=$(echo "$FE_FILES" | grep -E '\.(ts|tsx|js|jsx|json|css|md)$' || true)
  if [ -n "$FE_SRC_FILES" ]; then
    echo "  Prettier..."
    cd frontend
    npx prettier --check $FE_SRC_FILES 2>/dev/null || {
      echo "❌ Prettier check failed. Run 'cd frontend && npm run format' to fix."
      exit 1
    }
    cd ..
  fi

  # ESLint check
  FE_LINT_FILES=$(echo "$FE_FILES" | grep -E '\.(ts|tsx|js|jsx)$' || true)
  if [ -n "$FE_LINT_FILES" ]; then
    echo "  ESLint..."
    cd frontend
    npx eslint $FE_LINT_FILES 2>/dev/null || {
      echo "❌ ESLint check failed. Fix the errors and try again."
      exit 1
    }
    cd ..
  fi
fi

# Backend checks
BE_FILES=$(echo "$STAGED_FILES" | grep '^backend/.*\.go$' || true)
if [ -n "$BE_FILES" ]; then
  echo "📦 Checking backend files..."

  # gofmt check
  echo "  gofmt..."
  UNFORMATTED=$(gofmt -l $BE_FILES 2>/dev/null || true)
  if [ -n "$UNFORMATTED" ]; then
    echo "❌ gofmt check failed for:"
    echo "$UNFORMATTED"
    echo "Run 'gofmt -w' on these files."
    exit 1
  fi

  # golangci-lint (if installed)
  if command -v golangci-lint &> /dev/null; then
    echo "  golangci-lint..."
    cd backend
    golangci-lint run --new-from-rev=HEAD ./... 2>/dev/null || {
      echo "❌ golangci-lint check failed. Fix the errors and try again."
      exit 1
    }
    cd ..
  fi
fi

echo "✅ All pre-commit checks passed!"
